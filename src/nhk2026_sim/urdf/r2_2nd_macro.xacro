<?xml version="1.0" ?>
<robot name="r2_2nd_macro" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:include filename="$(find nhk2026_sim)/urdf/r2_2nd.trans" />

<xacro:macro name="r2_2nd" params="prefix:=''">
  <link name="base_footprint"/>

  <link name="base_link">
    <inertial>
      <origin xyz="-0.01897592062348662 -0.10555425475997327 0.14298974134420891" rpy="0 0 0"/>
      <mass value="13.072259884111979"/>
      <inertia ixx="1.047084" iyy="1.016092" izz="1.499027" ixy="0.043842" iyz="0.037546" ixz="0.102502"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://nhk2026_sim/meshes/base_link_r2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="steel_satin"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://nhk2026_sim/meshes/base_link_r2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="R2_step_climber_front_v2_1">
    <inertial>
      <origin xyz="0.016127121216774898 0.18644792175710703 -2.1817373602184276e-10" rpy="0 0 0"/>
      <mass value="1.2591666960686572"/>
      <inertia ixx="0.007687" iyy="0.000408" izz="0.007414" ixy="-8.7e-05" iyz="0.0" ixz="0.0"/>
    </inertial>
    <visual>
      <origin xyz="-0.335 -0.095 -0.06" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://nhk2026_sim/meshes/R2_step_climber_front_v2_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="steel_satin"/>
    </visual>
    <collision>
      <origin xyz="-0.335 -0.095 -0.06" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://nhk2026_sim/meshes/R2_step_climber_front_v2_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="R2_step_climber_front_v2_2">
    <inertial>
      <origin xyz="-0.016127121215468332 -0.18644792175710334 -2.1817370132737324e-10" rpy="0 0 0"/>
      <mass value="1.2591666960686572"/>
      <inertia ixx="0.007687" iyy="0.000408" izz="0.007414" ixy="-8.7e-05" iyz="-0.0" ixz="-0.0"/>
    </inertial>
    <visual>
      <origin xyz="0.335 -0.095 -0.06" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://nhk2026_sim/meshes/R2_step_climber_front_v2_2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="steel_satin"/>
    </visual>
    <collision>
      <origin xyz="0.335 -0.095 -0.06" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://nhk2026_sim/meshes/R2_step_climber_front_v2_2.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="R2_step_clibmer_arm_v2_1">
    <inertial>
      <origin xyz="-0.008920789398712332 0.004691281182066187 0.20281005076730813" rpy="0 0 0"/>
      <mass value="2.376029715091139"/>
      <inertia ixx="0.011384" iyy="0.031797" izz="0.022759" ixy="2.2e-05" iyz="0.000365" ixz="-0.000359"/>
    </inertial>
    <visual>
      <origin xyz="-0.019 0.37 -0.06" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://nhk2026_sim/meshes/R2_step_clibmer_arm_v2_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="steel_satin"/>
    </visual>
    <collision>
      <origin xyz="-0.019 0.37 -0.06" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://nhk2026_sim/meshes/R2_step_clibmer_arm_v2_1.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </collision>
  </link>

  <link name="lidar_front"/>
  <link name="lidar_back"/>

  <joint name="root" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
  </joint>

  <joint name="right" type="continuous">
    <origin xyz="0.335 0.095 0.06" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="R2_step_climber_front_v2_1"/>
    <axis xyz="1.0 0.0 0.0"/>
  </joint>

  <joint name="left" type="continuous">
    <origin xyz="-0.335 0.095 0.06" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="R2_step_climber_front_v2_2"/>
    <axis xyz="-1.0 0.0 0.0"/>
  </joint>

  <joint name="back" type="revolute">
    <origin xyz="0.019 -0.37 0.06" rpy="0 0 0"/>
    <parent link="base_link"/>
    <child link="R2_step_clibmer_arm_v2_1"/>
    <axis xyz="-1.0 0.0 0.0"/>
    <limit upper="6.283185" lower="3.141593" effort="100" velocity="100"/>
  </joint>

  <joint name="base_link_to_lidar_front" type="fixed">
    <origin xyz="-0.157 0.2885 0.0755" rpy="3.14159 0 1.5707"/>
    <parent link="base_link"/>
    <child link="lidar_front"/>
  </joint>

  <joint name="base_link_to_lidar_back" type="fixed">
    <origin xyz="0.270 -0.3615 0.0755" rpy="3.14159 0 0"/>
    <parent link="base_link"/>
    <child link="lidar_back"/>
  </joint>
  
  <gazebo>
    <plugin filename="libignition-gazebo-velocity-control-system.so"
            name="ignition::gazebo::systems::VelocityControl">
      <topic>/cmd_vel</topic>
    </plugin>
    
    <plugin filename="libignition-gazebo-odometry-publisher-system.so"
          name="ignition::gazebo::systems::OdometryPublisher">

      <odom_frame>odom</odom_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
      <odom_publish_frequency>40</odom_publish_frequency>
      <odom_topic>/odom</odom_topic>
      <tf_topic>/tf</tf_topic>
      <dimensions>3</dimensions>
      <gaussian_noise>0.0</gaussian_noise>
    </plugin>
  </gazebo>

  <gazebo reference="lidar_front">
    <sensor type="gpu_lidar" name="lidar_sensor_front">
      <ignition_frame_id>lidar_front</ignition_frame_id>
      <topic>/scan_front</topic>
      <alwaysOn>1</alwaysOn>
      <visualize>true</visualize>
      <update_rate>40</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>1080</samples>
            <resolution>1</resolution> 
            <min_angle>-2.35619</min_angle>
            <max_angle> 2.35619</max_angle>
          </horizontal>
          <vertical>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0.0</min_angle>
            <max_angle>0.0</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.1</min>
          <max>30.0</max>
          <resolution>0.001</resolution>
        </range>
      </ray>
    </sensor>
  </gazebo>

  <gazebo reference="lidar_back">
    <sensor type="gpu_lidar" name="lidar_sensor_back">
      <ignition_frame_id>lidar_back</ignition_frame_id>
      <topic>/scan_back</topic>
      <alwaysOn>1</alwaysOn>
      <visualize>true</visualize>
      <update_rate>40</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>1080</samples>
            <resolution>1</resolution>
            <min_angle>-2.35619</min_angle>
            <max_angle> 2.35619</max_angle>
          </horizontal>
          <vertical>
            <samples>1</samples>
            <resolution>1</resolution>
            <min_angle>0.0</min_angle>
            <max_angle>0.0</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.1</min>
          <max>30.0</max>
          <resolution>0.001</resolution>
        </range>
      </ray>
    </sensor>
  </gazebo>

  <gazebo reference="base_link">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
    <kp>1000000.0</kp>
    <kd>100.0</kd>
  </gazebo>

  <link name="livox_frame"/>

  <joint name="base_link_to_livox" type="fixed">
    <origin xyz="-0.325 -0.03 0.423" rpy="3.14159 0 -1.57"/>
    <parent link="base_link"/>
    <child link="livox_frame"/>
  </joint>

  <gazebo reference="livox_frame">
    <sensor type="gpu_lidar" name="livox_mid360_sensor">
      <ignition_frame_id>livox_frame</ignition_frame_id>
      <topic>/livox</topic>
      <alwaysOn>1</alwaysOn>
      <visualize>true</visualize>
      <update_rate>10</update_rate> <ray>
        <scan>
          <horizontal>
            <samples>1000</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
          <vertical>
            <samples>64</samples> <resolution>1</resolution>
            <min_angle>-0.12217</min_angle>
            <max_angle>0.90757</max_angle>
          </vertical>
        </scan>
        <range>
          <min>0.1</min>
          <max>40.0</max> <resolution>0.003</resolution>
        </range>
      </ray>
    </sensor>
  </gazebo>
  
  <gazebo>
    <plugin filename="gz-sim-joint-state-publisher-system"
            name="gz::sim::systems::JointStatePublisher" />
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>right</joint_name>
      <joint_index>0</joint_index>
      <topic>/right_sim</topic>
      <p_gain>900.0</p_gain>
      <i_gain>25.0</i_gain>
      <d_gain>48.0</d_gain>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>left</joint_name>
      <joint_index>0</joint_index>
      <topic>/left_sim</topic>
      <p_gain>900.0</p_gain>
      <i_gain>25.0</i_gain>
      <d_gain>140.0</d_gain>
    </plugin>
    <plugin filename="gz-sim-joint-position-controller-system"
            name="gz::sim::systems::JointPositionController">
      <joint_name>back</joint_name>
      <joint_index>0</joint_index>
      <topic>/back_sim</topic>
      <p_gain>900.0</p_gain>
      <i_gain>25.0</i_gain>
      <d_gain>48.0</d_gain>
    </plugin>
  </gazebo>
</xacro:macro>

</robot>
