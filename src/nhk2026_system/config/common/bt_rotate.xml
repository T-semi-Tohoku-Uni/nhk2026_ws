<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <include path="../common/bt_node_models.xml"/>
  <BehaviorTree ID="rotate">
    <Sequence>
      <ForceSuccess>
        <KeepRunningUntilFailure>
          <Sequence>
            <Inverter>
              <rotate_sub target_theta="{target_theta}"
                          tolerance="0.05"/>
            </Inverter>
            <Delay delay_msec="50">
              <pub_cmd_vel vx="0.0" vy="0.0" omega="{omega}"/>
            </Delay>
          </Sequence>
        </KeepRunningUntilFailure>
      </ForceSuccess>
      <pub_cmd_vel vx="0.0" vy="0.0" omega="0.0"/>
    </Sequence>
  </BehaviorTree>
</root>
