<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <include path="../common/bt_node_models.xml"/>
  <BehaviorTree ID="vel_tim">
    <Sequence>
      <ForceSuccess>
        <Timeout msec="{pub_msec}">
          <KeepRunningUntilFailure>
            <Delay delay_msec="50">
              <pub_cmd_vel vx="{vx}"
                          vy="{vy}"
                          omega="{omega}"/>
            </Delay>
          </KeepRunningUntilFailure>
        </Timeout>
      </ForceSuccess>

      <pub_cmd_vel vx="0.0"
                   vy="0.0"
                   omega="0.0"/>
    </Sequence>
  </BehaviorTree>
</root>
