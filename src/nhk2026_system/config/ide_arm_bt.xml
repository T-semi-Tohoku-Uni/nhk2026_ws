<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <include path="wait_for_trigger.xml"/>

  <BehaviorTree ID="MainTree">
    <Sequence>
      <SubTree ID="WaitForTrigger"
               _autoremap="false"/>
      <move_arm y="0.60"
                z="0.6"
                roll="-1.57"
                max_speed="0.1"
                max_acc="0.01"/>
      <move_arm y="1.0"
                z="0.180375"
                roll="0.0"
                max_speed="0.1"
                max_acc="0.01"/>
      <service_vacuum value="true" />
      <move_arm y="1.2"
                z="0.180375"
                roll="0.0"
                max_speed="0.1"
                max_acc="0.01"/>
      <move_arm y="1"
                z="0.3"
                roll="0.0"
                max_speed="0.1"
                max_acc="0.01"/>
      <move_arm y="0.8"
                z="0.449"
                roll="-1.57"
                max_speed="0.1"
                max_acc="0.01"/>
      <move_arm y="0.1"
                z="0.8"
                roll="-1.57"
                max_speed="0.1"
                max_acc="0.01"/>
      <service_vacuum value="false" />
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="move_arm"
            editable="true">
      <input_port name="y"/>
      <input_port name="z"/>
      <input_port name="roll"/>
      <input_port name="max_speed"/>
      <input_port name="max_acc"/>
    </Action>
    <Action ID="service_vacuum"
            editable="true">
      <input_port name="value"/>
    </Action>
  </TreeNodesModel>

</root>
