<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <include path="../common/bt_node_models.xml"/>

  <BehaviorTree ID="MartialClub">
    <Sequence>
      <generate_route x="-1"
                      y="2"
                      theta="0.0"/>
      <SubTree ID="vel_tim"
               vx="-0.2"
               vy="0"
               omega="0"
               pub_msec="0"
               _autoremap="true"/>
      <follow_route/>
      <takano_hand step="2"
                   pos="5.0"/>
      <takano_hand step="3"
                   pos="5.0"/>
      <takano_hand step="4"
                   pos="5.0"/>
      <takano_hand step="5"
                   pos="5.0"/>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="follow_route"
            editable="true"/>
    <Action ID="generate_route"
            editable="true">
      <input_port name="x"/>
      <input_port name="y"/>
      <input_port name="theta"
                  default="0.0"/>
    </Action>
    <Action ID="takano_hand"
            editable="true">
      <input_port name="step"/>
      <input_port name="pos"
                  default="5.0"/>
    </Action>
    <SubTree ID="vel_tim">
      <input_port name="vx"/>
      <input_port name="vy"/>
      <input_port name="omega"/>
      <input_port name="pub_msec"/>
    </SubTree>
  </TreeNodesModel>

</root>
