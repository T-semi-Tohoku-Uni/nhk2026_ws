<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <include path="../common/bt_node_models.xml"/>

  <BehaviorTree ID="MartialClub">
    <Sequence>
      <move_arm y="0.248"
                z="0.588"
                roll="-1.942"
                max_speed="0.5"
                max_acc="0.1"/>
      <generate_route x="-1.5"
                      y="1.45"
                      theta="3.142"/>
      <follow_outline/>
      <move_legs right_angle="3.14"
                 left_angle="3.14"
                 back_angle="0.0"/>
      <generate_route x="-0.57"
                      y="1.5"
                      theta="3.142"/>
      <follow_outline/>
      <generate_route x="-0.51"
                      y="1.5"
                      theta="3.142"/>
      <ForceSuccess>
        <Timeout msec="15000">
          <follow_detail/>
        </Timeout>
      </ForceSuccess>
      <takano_hand step="1"
                   pos="5.0"/>
      <Delay delay_msec="1000">
        <SubTree ID="vel_tim"
                 vx="0.0"
                 vy="-0.05"
                 omega="0.05"
                 pub_msec="500"
                 _autoremap="true"/>
      </Delay>
      <Delay delay_msec="1000">
        <takano_hand step="2"
                     pos="5.0"/>
      </Delay>
      <Delay delay_msec="1000">
        <SubTree ID="vel_tim"
                 vx="0.0"
                 vy="-0.1"
                 omega="0"
                 pub_msec="1000"
                 _autoremap="true"/>
      </Delay>
      <move_legs right_angle="3.491"
                 left_angle="3.491"
                 back_angle="-0.3491"/>
      <takano_hand step="3"
                   pos="5.0"/>
      <move_legs right_angle="3.14"
                 left_angle="3.14"
                 back_angle="0.0"/>
      <takano_hand step="4"
                   pos="5.0"/>
      <takano_hand step="5"
                   pos="5.0"/>
      <generate_route x="-1.5"
                      y="0.6"
                      theta="1.57"/>
      <follow_outline/>
      <move_legs right_angle="0.0"
                 left_angle="0.0"
                 back_angle="1.57"/>
      <SubTree ID="WaitForTrigger"/>
      <takano_hand step="6"
                   pos="5.0"/>
      <SubTree ID="WaitForTrigger"/>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="follow_detail"
            editable="true"/>
    <Action ID="follow_outline"
            editable="true"/>
    <Action ID="generate_route"
            editable="true">
      <input_port name="x"/>
      <input_port name="y"/>
      <input_port name="theta"
                  default="0.0"/>
    </Action>
    <Action ID="move_arm"
            editable="true">
      <input_port name="y"/>
      <input_port name="z"/>
      <input_port name="roll"/>
      <input_port name="max_speed"/>
      <input_port name="max_acc"/>
    </Action>
    <Action ID="move_legs"
            editable="true">
      <input_port name="right_angle"/>
      <input_port name="left_angle"/>
      <input_port name="back_angle"/>
    </Action>
    <Action ID="takano_hand"
            editable="true">
      <input_port name="step"/>
      <input_port name="pos"
                  default="5.0"/>
    </Action>
    <SubTree ID="vel_tim">
      <input_port name="vx"/>
      <input_port name="vy"/>
      <input_port name="omega"/>
      <input_port name="pub_msec"/>
    </SubTree>
  </TreeNodesModel>

</root>
