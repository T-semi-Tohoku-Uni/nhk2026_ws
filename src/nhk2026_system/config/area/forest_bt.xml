<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <include path="../operation/arm_front_step.xml"/>

  <include path="../operation/arm_up_step.xml"/>

  <include path="../operation/arm_down_step.xml"/>

  <include path="../operation/kfs_stack.xml"/>

  <include path="../common/bt_node_models.xml"/>

  <BehaviorTree ID="Forest">
    <Sequence>
      <generate_route x="-1.8"
                      y="2.6"
                      theta="0.0"/>
      <follow_route/>
      <SubTree ID="arm_up_step"/>
      <step_move command="step up"/>
      <reset_mcl x="-1.8"
                 y="3.8"
                 z="0.2"
                 theta="0.0"/>
      <Delay delay_msec="5000">
        <generate_route x="-1.8"
                        y="3.9"
                        theta="0.0"/>
      </Delay>
      <follow_route/>
      <step_move command="step up"/>
      <reset_mcl x="-1.8"
                 y="5.0"
                 z="0.4"
                 theta="0.0"/>
      <Delay delay_msec="5000">
        <generate_route x="-1.8"
                        y="5.0"
                        theta="0.0"/>
      </Delay>
      <follow_route/>
      <generate_route x="-1.8"
                      y="5.0"
                      theta="-1.57"/>
      <follow_route/>
      <step_move command="step down"/>
      <reset_mcl x="-3.0"
                 y="5.0"
                 z="0.2"
                 theta="0.0"/>
      <Delay delay_msec="5000">
        <generate_route x="-3.0"
                        y="5.0"
                        theta="-1.57"/>
      </Delay>
      <follow_route/>
      <SubTree ID="rotate"
               target_theta="0.0"
               omega="1"/>
      <generate_route x="-3.0"
                      y="5.1"
                      theta="0.0"/>
      <follow_route/>
      <step_move command="step up"/>
      <reset_mcl x="-3.0"
                 y="6.2"
                 z="0.4"
                 theta="0.0"/>
      <Delay delay_msec="5000">
        <SubTree ID="rotate"
                 target_theta="3.14"
                 omega="1"
                 _autoremap="true"/>
      </Delay>
      <step_move command="step down"/>
      <SubTree ID="rotate"
               target_theta="3.14"
               omega="1"
               _autoremap="true"/>
      <Delay delay_msec="1000">
        <step_move command="step down"/>
      </Delay>
      <reset_mcl x="-3.0"
                 y="8.6"
                 z="0.0"
                 theta="0.0"/>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="follow_route"
            editable="true"/>
    <Action ID="generate_route"
            editable="true">
      <input_port name="x"/>
      <input_port name="y"/>
      <input_port name="theta"
                  default="0.0"/>
    </Action>
    <Action ID="reset_mcl"
            editable="true">
      <input_port name="x"/>
      <input_port name="y"/>
      <input_port name="z"/>
      <input_port name="theta"/>
    </Action>
    <SubTree ID="rotate">
      <input_port name="target_theta"/>
      <input_port name="omega"/>
    </SubTree>
    <Action ID="step_move"
            editable="true">
      <input_port name="command"/>
    </Action>
  </TreeNodesModel>

</root>
