<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <include path="../operation/arm_put_shelf.xml"/>

  <include path="../common/bt_node_models.xml"/>

  <BehaviorTree ID="Arena">
    <Sequence>
      <generate_route x="-3.0"
                      y="7.0"
                      theta="-1.57"/>
      <follow_route/>
      <waypoint x="-4.5"
                y="7.7"/>
      <waypoint x="-4.5"
                y="9.0"/>
      <generate_route x="-2"
                      y="9.0"
                      theta="-1.57"/>
      <follow_route/>
      <SubTree ID="arm_put_shelf"/>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="follow_route"
            editable="true"/>
    <Action ID="generate_route"
            editable="true">
      <input_port name="x"/>
      <input_port name="y"/>
      <input_port name="theta"
                  default="0.0"/>
    </Action>
    <Action ID="waypoint"
            editable="true">
      <input_port name="x"/>
      <input_port name="y"/>
    </Action>
  </TreeNodesModel>

</root>
