<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <include path="../operation/arm_put_shelf.xml"/>

  <include path="../common/bt_node_models.xml"/>

  <BehaviorTree ID="Arena">
    <Sequence>
      <generate_route x="-2.0"
                      y="1.0"
                      theta="0.0"/>
      <waypoint x="10"
                y="10"/>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="generate_route"
            editable="true">
      <input_port name="x"/>
      <input_port name="y"/>
      <input_port name="theta"
                  default="0.0"/>
    </Action>
    <Action ID="waypoint"
            editable="true">
      <input_port name="x"/>
      <input_port name="y"/>
    </Action>
  </TreeNodesModel>

</root>
