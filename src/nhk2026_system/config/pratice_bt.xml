<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4"
      main_tree_to_execute="MainTree">
  <include path="area/arena_bt.xml"/>

  <include path="area/martial_club_bt.xml"/>

  <include path="area/forest_bt.xml"/>

  <include path="common/bt_node_models.xml"/>

  <include path="common/wait_for_trigger.xml"/>

  <BehaviorTree ID="MainTree">
    <Sequence>
      <generate_route x="-4.0"
                      y="1.0"
                      theta="0.0"/>
      <follow_route/>
      <generate_route x="-5.5"
                      y="8.0"
                      theta="0.0"/>
      <follow_route/>
      <generate_route x="-5.5"
                      y="8.0"
                      theta="1.57"/>
      <follow_route/>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="follow_route"
            editable="true"/>
    <Action ID="generate_route"
            editable="true">
      <input_port name="x"/>
      <input_port name="y"/>
      <input_port name="theta"
                  default="0.0"/>
    </Action>
  </TreeNodesModel>

</root>
