<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4"
      main_tree_to_execute="MainTree">
  <include path="area/arena_bt.xml"/>

  <include path="area/martial_club_bt.xml"/>

  <include path="area/forest_bt.xml"/>

  <include path="common/bt_node_models.xml"/>

  <include path="common/wait_for_trigger.xml"/>

  <BehaviorTree ID="MainTree">
    <Sequence>
      <generate_route x="-4.2"
                      y="2.6"
                      theta="0.0"/>
      <follow_route/>
      <step_move command="step up"/>
      <SubTree ID="rotate"
               target_theta="3.14"
               omega="1"/>
      <reset_mcl x="-4.2"
                 y="3.8"
                 z="0.2"
                 theta="reset_mcl0.0"/>
      <Delay delay_msec="Delay4000">
        <generate_route x="-4.2"
                        y="3.8"
                        theta="3.14"/>
      </Delay>
      <follow_route/>
      <step_move command="step down"/>
      <reset_mcl x="-4.2"
                 y="5.0"
                 z="0.0"
                 theta="0.0"/>
      <Delay delay_msec="4000">
        <generate_route x="-4.2"
                        y="5.0"
                        theta="3.14"/>
      </Delay>
      <follow_route/>
      <SubTree ID="rotate"
               target_theta="0.0"
               omega="1"/>
      <step_move command="step up"/>
      <SubTree ID="rotate"
               target_theta="3.14"
               omega="1"/>
      <reset_mcl x="-4.2"
                 y="6.2"
                 z="0.2"
                 theta="0.0"/>
      <Delay delay_msec="4000">
        <generate_route x="-4.2"
                        y="6.2"
                        theta="3.14"/>
      </Delay>
      <follow_route/>
      <step_move command="step  down"/>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="follow_route"
            editable="true"/>
    <Action ID="generate_route"
            editable="true">
      <input_port name="x"/>
      <input_port name="y"/>
      <input_port name="theta"
                  default="0.0"/>
    </Action>
    <Action ID="reset_mcl"
            editable="true">
      <input_port name="x"/>
      <input_port name="y"/>
      <input_port name="z"/>
      <input_port name="theta"/>
    </Action>
    <SubTree ID="rotate">
      <input_port name="target_theta"/>
      <input_port name="omega"/>
    </SubTree>
    <Action ID="step_move"
            editable="true">
      <input_port name="command"/>
    </Action>
  </TreeNodesModel>

</root>
