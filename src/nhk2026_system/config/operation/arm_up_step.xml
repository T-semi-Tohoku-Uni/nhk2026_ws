<root BTCPP_format="4">
  <BehaviorTree ID="arm_up_step">
    <Sequence>
    </Sequence>
  </BehaviorTree>
  
  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="move_arm"
            editable="true">
      <input_port name="y"/>
      <input_port name="z"/>
      <input_port name="roll"/>
      <input_port name="max_speed"/>
      <input_port name="max_acc"/>
    </Action>
    <Action ID="service_vacuum"
            editable="true">
