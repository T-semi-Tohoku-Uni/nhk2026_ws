    <Action ID="linear_path"
            editable="true">
      <input_port name="x"/>
      <input_port name="y"/>
      <input_port name="is_return"/>
    </Action>
    <Action ID="follow_route"
            editable="true"/>
    <Action ID="generate_route"
            editable="true">
      <input_port name="x">TODO</input_port>
      <input_port name="y">TODO</input_port>
      <input_port name="theta"
                  default="0.0"/>
    </Action>
  </TreeNodesModel>
