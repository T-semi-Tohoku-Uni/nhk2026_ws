<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4">
  <include path="../common/bt_node_models.xml"/>

  <BehaviorTree ID="arm_put_shelf">
    <Sequence>
      <move_arm y="-0.1"
                z="0.711455"
                roll="-1.57"
                max_speed="1.0"
                max_acc="0.5"/>
      <service_vacuum_stack value="false"/>
      <Delay delay_msec="1000">
        <service_vacuum value="true"/>
      </Delay>
      <move_arm y="-0.1"
                z="0.62"
                roll="-1.57"
                max_speed="1.0"
                max_acc="0.05"/>
      <move_arm y="-0.1"
                z="0.71"
                roll="-1.57"
                max_speed="1.0"
                max_acc="0.5"/>
      <move_arm y="0.011076"
                z="0.852822"
                roll="-1.57"
                max_speed="1.0"
                max_acc="0.5"/>
      <move_arm y="0.139777"
                z="1.062562"
                roll="0.17"
                max_speed="1.0"
                max_acc="0.5"/>
      <generate_route x="-0.5"
                      y="11.3"
                      theta="-1.57"/>
      <ForceSuccess>
        <Timeout msec="6000">
          <follow_detail/>
        </Timeout>
      </ForceSuccess>
      <move_arm y="0.404131"
                z="1.008237"
                roll="0.14"
                max_speed="1.0"
                max_acc="0.5"/>
      <service_vacuum value="false"/>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="follow_detail"
            editable="true"/>
    <Action ID="generate_route"
            editable="true">
      <input_port name="x"/>
      <input_port name="y"/>
      <input_port name="theta"
                  default="0.0"/>
    </Action>
    <Action ID="move_arm"
            editable="true">
      <input_port name="y"/>
      <input_port name="z"/>
      <input_port name="roll"/>
      <input_port name="max_speed"/>
      <input_port name="max_acc"/>
    </Action>
    <Action ID="service_vacuum"
            editable="true">
      <input_port name="value"/>
    </Action>
    <Action ID="service_vacuum_stack"
            editable="true">
      <input_port name="value"/>
    </Action>
  </TreeNodesModel>

</root>
