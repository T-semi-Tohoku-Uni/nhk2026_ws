<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4"
      main_tree_to_execute="MainBT">
  <BehaviorTree ID="MainBT">
    <Sequence>
      <Sequence>
        <Delay delay_msec="1000">
          <waypoint x="0.5"
                    y="1.0"/>
        </Delay>
        <waypoint x="0.5"
                  y="9.0"/>
        <waypoint x="5.5"
                  y="9.0"/>
        <waypoint x="5.5"
                  y="2.0"/>
        <generate_route x="1.45"
                        y="0.45"
                        theta="0.0"/>
        <follow_route/>
      </Sequence>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="follow_route"
            editable="true"/>
    <Action ID="generate_route"
            editable="true">
      <input_port name="x">TODO</input_port>
      <input_port name="y">TODO</input_port>
      <input_port name="theta"
                  default="0.0"/>
    </Action>
    <Action ID="waypoint"
            editable="true">
      <input_port name="x"/>
      <input_port name="y"/>
    </Action>
  </TreeNodesModel>

</root>
