<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4"
      main_tree_to_execute="MainBT">
  <BehaviorTree ID="MainBT">
    <Sequence>
      <generate_route x="-3.025"
                      y="0.95"
                      theta="0.0"/>
      <follow_route/>
      <ball_path x="0"
                 y="0"
                 is_return="0"/>
      <follow_route/>
    </Sequence>
  </BehaviorTree>

  <!-- Description of Node Models (used by Groot) -->
  <TreeNodesModel>
    <Action ID="ball_path"
            editable="true">
      <input_port name="x"/>
      <input_port name="y"/>
      <input_port name="is_return"/>
    </Action>
    <Action ID="follow_route"
            editable="true"/>
    <Action ID="generate_route"
            editable="true">
      <input_port name="x">TODO</input_port>
      <input_port name="y">TODO</input_port>
      <input_port name="theta"
                  default="0.0"/>
    </Action>
  </TreeNodesModel>

</root>
